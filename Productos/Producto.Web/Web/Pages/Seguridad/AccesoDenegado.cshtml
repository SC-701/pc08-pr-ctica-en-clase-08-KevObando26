@page
@model Web.Pages.Seguridad.AccesoDenegadoModel
@{
    ViewData["Title"] = "Acceso denegado";
}

<section class="auth-wrapper text-center">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 auth-card p-4 p-md-5">

                
                <div class="mb-4">
                    <i class="bi bi-shield-lock-fill access-denied-icon"></i>
                </div>

               
                <h1 class="section-heading display-3 mb-2">403</h1>

                
                <h3 class="section-subheading mb-3">Acceso denegado</h3>

                
                <p class="text-muted mb-4">
                    🤨 Parece que intentaste entrar donde no debías...<br />
                    Este recurso está más protegido que el último pedazo de pizza 🍕
                </p>

                
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-page="/Index" class="btn btn-primary">
                        <i class="bi bi-house-door me-1"></i> Volver al inicio
                    </a>

                    <a asp-page="/Seguridad/Login" class="btn btn-outline-secondary">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Iniciar sesión
                    </a>
                </div>

            </div>
        </div>
    </div>
</section>